@{
    ViewData["Title"] = "Account verified";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm text-center border-0">
            <div class="card-body p-5">
                <i class="bi bi-check-circle-fill text-success notification-icon"></i>
                <h3 class="mt-4 fw-bold">Account successfully activated!</h3>
                <p class="text-muted mt-3 fs-5">
                    Your account has been successfully verified. Now you can continue using the system.
                </p>
                <a asp-controller="Users" asp-action="GetAllUsers" class="btn btn-primary btn-lg mt-4">
                    <i class="bi bi-house-door me-2"></i>To the admin panel
                </a>
            </div>
        </div>
    </div>
</div>